# ============================================================
# Inso SIEM — Environment Variables Reference
# Copy this file to .env and fill in all values before running.
# NEVER commit the actual .env file to source control.
# ============================================================

# ────────────────────────────────────────────────────────────
# APPLICATION
# ────────────────────────────────────────────────────────────

# Human-readable name shown in the UI and emails
APP_NAME=Inso SIEM

# External base URL (no trailing slash)
APP_URL=https://siem.example.com

# Local/public host ports published by the Nginx reverse proxy
HTTP_PORT=8011
HTTPS_PORT=8443

# Application environment: development | staging | production
APP_ENV=production

# Python log level: DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Default organisation name created on first boot
DEFAULT_ORG_NAME=My Organization

# Default admin user email (created on first boot)
DEFAULT_ADMIN_EMAIL=admin@inso.local

# Default admin user password (change immediately after first login)
DEFAULT_ADMIN_PASSWORD=Admin123!

# Vite frontend API base URL (used during Docker build)
VITE_API_BASE_URL=/api/v1

# Vite WebSocket URL (used during Docker build)
VITE_WS_URL=wss://siem.example.com/api/v1/ws

# ────────────────────────────────────────────────────────────
# POSTGRESQL
# ────────────────────────────────────────────────────────────

# PostgreSQL database name
POSTGRES_DB=inso_siem

# PostgreSQL superuser username
POSTGRES_USER=inso

# PostgreSQL superuser password (use a strong random value)
POSTGRES_PASSWORD=changeme_postgres

# PostgreSQL host (use service name inside Docker)
POSTGRES_HOST=postgres

# PostgreSQL port
POSTGRES_PORT=5432

# Full async DSN (auto-constructed in docker-compose; set manually for external DB)
# POSTGRES_DSN=postgresql+asyncpg://inso:changeme@postgres:5432/inso_siem

# ────────────────────────────────────────────────────────────
# CLICKHOUSE
# ────────────────────────────────────────────────────────────

# ClickHouse database name
CLICKHOUSE_DB=inso_events

# ClickHouse user
CLICKHOUSE_USER=inso_ch

# ClickHouse password
CLICKHOUSE_PASSWORD=changeme_clickhouse

# ClickHouse HTTP host (used for health checks and REST queries)
CLICKHOUSE_HOST=clickhouse

# ClickHouse HTTP port
CLICKHOUSE_HTTP_PORT=8123

# ClickHouse native TCP port
CLICKHOUSE_TCP_PORT=9000

# ────────────────────────────────────────────────────────────
# REDIS
# ────────────────────────────────────────────────────────────

# Redis host
REDIS_HOST=redis

# Redis port
REDIS_PORT=6379

# Redis authentication password
REDIS_PASSWORD=changeme_redis

# Redis database index for main app
REDIS_DB=0

# Redis database index for Celery broker (if used)
REDIS_CELERY_DB=1

# Maximum memory Redis will use before evicting keys
REDIS_MAX_MEMORY=512mb

# ────────────────────────────────────────────────────────────
# NATS / JETSTREAM
# ────────────────────────────────────────────────────────────

# NATS server URL (nats:// scheme)
NATS_URL=nats://nats:4222

# NATS authentication username
NATS_USER=inso_nats

# NATS authentication password
NATS_PASSWORD=changeme_nats

# NATS monitoring HTTP port
NATS_MONITOR_PORT=8222

# ────────────────────────────────────────────────────────────
# MINIO OBJECT STORAGE
# ────────────────────────────────────────────────────────────

# MinIO root access key (equivalent to AWS_ACCESS_KEY_ID)
MINIO_ROOT_USER=insoadmin

# MinIO root secret key (equivalent to AWS_SECRET_ACCESS_KEY)
MINIO_ROOT_PASSWORD=changeme_minio_secret

# MinIO S3 endpoint (host:port inside Docker)
MINIO_ENDPOINT=minio:9000

# Set to "false" inside Docker (no TLS between containers)
MINIO_USE_SSL=false

# Bucket used for case attachments
MINIO_BUCKET_ATTACHMENTS=inso-attachments

# Bucket used for report exports
MINIO_BUCKET_REPORTS=inso-reports

# Bucket used for GeoIP / threat-feed files
MINIO_BUCKET_FEEDS=inso-feeds

# Browser console redirect URL (for MinIO UI)
MINIO_BROWSER_REDIRECT_URL=http://localhost:9001

# ────────────────────────────────────────────────────────────
# JWT & AUTHENTICATION
# ────────────────────────────────────────────────────────────

# HMAC secret used for symmetric JWT signing (min 64 chars, random)
JWT_SECRET_KEY=REPLACE_WITH_64_CHAR_RANDOM_HEX_STRING

# Algorithm currently supported by backend JWT helpers: HS256
JWT_ALGORITHM=HS256

# Access token lifetime in minutes
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15

# Refresh token lifetime in days
JWT_REFRESH_TOKEN_EXPIRE_DAYS=7

# Reserved for future RS256 support.
# JWT_PRIVATE_KEY_PATH=certs/jwt_private.pem
# JWT_PUBLIC_KEY_PATH=certs/jwt_public.pem

# Number of bcrypt hashing rounds (12 is a safe default)
BCRYPT_ROUNDS=12

# ────────────────────────────────────────────────────────────
# ENCRYPTION
# ────────────────────────────────────────────────────────────

# Fernet/AES key for encrypting secrets at rest (32 url-safe base64 bytes)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=REPLACE_WITH_FERNET_KEY

# ────────────────────────────────────────────────────────────
# AI — OPENAI
# ────────────────────────────────────────────────────────────

# OpenAI API key (leave blank to disable cloud AI features)
OPENAI_API_KEY=

# OpenAI model used for alert summarisation and chat
OPENAI_MODEL=gpt-4o

# Maximum tokens per OpenAI completion
OPENAI_MAX_TOKENS=2048

# OpenAI request timeout in seconds
OPENAI_TIMEOUT=30

# ────────────────────────────────────────────────────────────
# AI — OLLAMA (self-hosted)
# ────────────────────────────────────────────────────────────

# Ollama base URL (leave blank to disable local AI)
OLLAMA_BASE_URL=http://ollama:11434

# Default Ollama model for local inference
OLLAMA_MODEL=llama3

# ────────────────────────────────────────────────────────────
# EMAIL / SMTP
# ────────────────────────────────────────────────────────────

# SMTP server host
SMTP_HOST=smtp.example.com

# SMTP server port (587 for STARTTLS, 465 for SSL)
SMTP_PORT=587

# SMTP username
SMTP_USER=alerts@example.com

# SMTP password
SMTP_PASSWORD=changeme_smtp

# Use TLS: true | false
SMTP_TLS=true

# Sender display name
SMTP_FROM_NAME=Inso SIEM Alerts

# Sender email address
SMTP_FROM_EMAIL=alerts@example.com

# ────────────────────────────────────────────────────────────
# GEOIP
# ────────────────────────────────────────────────────────────

# MaxMind licence key for downloading GeoLite2 databases
# Register free at https://www.maxmind.com/en/geolite2/signup
MAXMIND_LICENSE_KEY=

# Path where GeoIP city database is mounted inside the backend container
GEOIP_DB_PATH=/opt/geoip/GeoLite2-City.mmdb

# GeoIP city database filename
GEOIP_CITY_DB=GeoLite2-City.mmdb

# GeoIP ASN database filename
GEOIP_ASN_DB=GeoLite2-ASN.mmdb

# ────────────────────────────────────────────────────────────
# RATE LIMITING
# ────────────────────────────────────────────────────────────

# Requests per minute allowed per IP for auth endpoints
RATE_LIMIT_AUTH_RPM=30

# Requests per minute allowed per IP for general API
RATE_LIMIT_API_RPM=600

# ────────────────────────────────────────────────────────────
# FEATURE FLAGS
# ────────────────────────────────────────────────────────────

# Enable MITRE ATT&CK enrichment
FEATURE_MITRE_ENRICHMENT=true

# Enable IOC feed auto-sync
FEATURE_IOC_AUTOSYNC=true

# Enable AI-powered alert triage
FEATURE_AI_TRIAGE=true

# Enable playbook auto-execution
FEATURE_PLAYBOOK_AUTO=false

# Enable email notifications
FEATURE_EMAIL_NOTIFICATIONS=true
